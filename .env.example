# =============================================================================
# Metabase POC - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Metabase Instance ---
# Your existing Metabase instance URL (no trailing slash)
METABASE_INSTANCE_URL=https://your-metabase-instance.com

# API key for local development (Admin > Settings > Authentication > API Keys)
# Only works on localhost - do NOT use in production
METABASE_API_KEY=your_api_key_here

# JWT shared secret for production auth (Admin > Settings > Authentication > JWT)
METABASE_JWT_SECRET=your_jwt_shared_secret_here

# Auth mode: "apikey" for local dev, "jwt" for production
VITE_AUTH_MODE=apikey

# --- Vite env vars (accessible in React client) ---
VITE_METABASE_INSTANCE_URL=https://your-metabase-instance.com
VITE_METABASE_API_KEY=your_api_key_here

# Dashboard ID to display by default (numeric ID from your Metabase)
VITE_DASHBOARD_ID=1

# --- Server config ---
SERVER_PORT=4200

# --- Databricks Connection Reference ---
# These are NOT used by the app directly.
# Configure Databricks in Metabase Admin UI: Admin > Databases > Add Database > Databricks
# These fields are here as a reference for your setup.
DATABRICKS_HOST=xxxxxxxxxx.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/endpoints/abcdef1234567890
DATABRICKS_TOKEN=your_databricks_pat_here
DATABRICKS_CATALOG=your_default_catalog
